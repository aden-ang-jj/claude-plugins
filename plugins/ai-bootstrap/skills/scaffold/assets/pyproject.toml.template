[project]
name = "{{PROJECT_NAME}}"
version = "0.1.0"
description = "AI app scaffolded by /ai-bootstrap:scaffold"
requires-python = ">=3.11"
dependencies = [
    "openai>=1.50.0",
    "pydantic-settings>=2.5.0",
    "python-dotenv>=1.0.0",
]

[dependency-groups]
dev = [
    "mypy>=1.11.0",
    "pytest>=8.0.0",
    "ruff>=0.6.0",
]

[tool.ruff]
line-length = 100
target-version = "py311"

[tool.mypy]
python_version = "3.11"
strict = true
