# Which provider llm.py should use for each call.
# Change this and the matching *_API_KEY below to swap providers.
LLM_PROVIDER={{DEFAULT_PROVIDER}}

# --- API keys (paste the one matching LLM_PROVIDER above) ---
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPINFRA_API_KEY=

# --- Optional knobs (sane defaults if left blank) ---
# Override the per-provider default model: e.g. gpt-4o, anthropic/claude-opus-4
LLM_DEFAULT_MODEL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# Logging
LOG_LEVEL=INFO
